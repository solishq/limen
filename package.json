{
  "name": "limen-ai",
  "version": "2.0.0",
  "description": "Governed knowledge engine for AI agents. Store beliefs with confidence, evidence chains, and lifecycle governance. SQLite-powered, zero-config, single dependency.",
  "type": "module",
  "license": "Apache-2.0",
  "author": {
    "name": "SolisHQ",
    "url": "https://solishq.ai"
  },
  "homepage": "https://github.com/solishq/limen",
  "repository": {
    "type": "git",
    "url": "https://github.com/solishq/limen.git"
  },
  "bugs": {
    "url": "https://github.com/solishq/limen/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "cognitive-os",
    "agent",
    "framework",
    "anthropic",
    "openai",
    "gemini",
    "groq",
    "mistral",
    "ollama",
    "sqlite",
    "mission",
    "orchestration",
    "transport",
    "streaming",
    "typescript",
    "memory",
    "knowledge",
    "remember",
    "recall",
    "agent-memory",
    "knowledge-engine",
    "beliefs",
    "governed",
    "ai-agents"
  ],
  "exports": {
    ".": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./reference-agent": {
      "types": "./dist/reference-agent/index.d.ts",
      "import": "./dist/reference-agent/index.js"
    },
    "./transport": {
      "types": "./dist/substrate/transport/index.d.ts",
      "import": "./dist/substrate/transport/index.js"
    }
  },
  "main": "./dist/api/index.js",
  "types": "./dist/api/index.d.ts",
  "files": [
    "dist/",
    "examples/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "workspaces": [
    "packages/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "npx tsx --test $(find tests -path tests/scaffold -prune -o -name '*.test.ts' -print)",
    "test:all": "npx tsx --test $(find tests -name '*.test.ts')",
    "ci": "npm run typecheck && npm run build && npm run test",
    "test:coverage": "c8 --reporter=text --reporter=lcov npx tsx --test $(find tests -path tests/scaffold -prune -o -name '*.test.ts' -print)",
    "docs": "typedoc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "sqlite-vec": "^0.1.9"
  }
}
